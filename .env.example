# Bu fayl NAMUNA uchun! Haqiqiy qiymatlarni .env ga yozing!

# Bot token (@BotFather dan)
BOT_TOKEN=your_bot_token_here

# Database URL
DATABASE_URL=sqlite+aiosqlite:///worldskills.db

# Admin Telegram ID
ADMIN_ID=your_telegram_id_here

# Groq API Key (console.groq.com dan)
GROQ_API_KEY=your_groq_api_key_here

# Secret key (xavfsizlik uchun)
SECRET_KEY=your_secret_key_here

# Vercel URL (Mini App)
WEBAPP_URL=https://your-app.vercel.app
