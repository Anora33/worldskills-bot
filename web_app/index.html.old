<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WorldSkills Shanghai 2026</title>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --bg-primary: #000000;
            --bg-secondary: #0a0a0a;
            --bg-card: #111111;
            --text-primary: #ffffff;
            --text-secondary: #a0a0a0;
            --border: #222222;
            --accent: #ffffff;
            --gradient: linear-gradient(135deg, #ffffff 0%, #888888 100%);
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            min-height: 100vh;
            padding-bottom: 90px;
            overflow-x: hidden;
        }

        /* Animated Background */
        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background:
                radial-gradient(circle at 20% 50%, rgba(255,255,255,0.03) 0%, transparent 50%),
                radial-gradient(circle at 80% 80%, rgba(255,255,255,0.03) 0%, transparent 50%);
            pointer-events: none;
            z-index: 0;
            animation: bgPulse 8s ease-in-out infinite;
        }

        @keyframes bgPulse {
            0%, 100% { opacity: 0.5; }
            50% { opacity: 1; }
        }

        /* Header */
        .header {
            background: var(--gradient);
            padding: 40px 20px;
            text-align: center;
            position: relative;
            overflow: hidden;
            animation: slideDown 0.6s ease-out;
        }

        .header::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: repeating-linear-gradient(
                45deg,
                transparent,
                transparent 10px,
                rgba(0,0,0,0.05) 10px,
                rgba(0,0,0,0.05) 20px
            );
            animation: shimmer 3s linear infinite;
        }

        @keyframes shimmer {
            0% { transform: translate(-50%, -50%) rotate(0deg); }
            100% { transform: translate(-50%, -50%) rotate(360deg); }
        }

        @keyframes slideDown {
            from { opacity: 0; transform: translateY(-50px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .header h1 {
            font-size: 28px;
            margin-bottom: 10px;
            position: relative;
            z-index: 1;
            animation: fadeIn 0.8s ease-out 0.2s both;
        }

        .header p {
            opacity: 0.9;
            font-size: 14px;
            position: relative;
            z-index: 1;
            animation: fadeIn 0.8s ease-out 0.4s both;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Bottom Navigation */
        .bottom-nav {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: var(--bg-secondary);
            border-top: 1px solid var(--border);
            display: flex;
            justify-content: space-around;
            padding: 12px 0;
            z-index: 1000;
            backdrop-filter: blur(20px);
            animation: slideUp 0.6s ease-out;
        }

        @keyframes slideUp {
            from { opacity: 0; transform: translateY(50px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .nav-item {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 8px;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            color: var(--text-secondary);
            position: relative;
        }

        .nav-item::before {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 0;
            height: 3px;
            background: var(--accent);
            transition: width 0.3s ease;
        }

        .nav-item.active {
            color: var(--text-primary);
        }

        .nav-item.active::before {
            width: 60%;
        }

        .nav-item:hover {
            color: var(--text-primary);
            transform: translateY(-5px);
        }

        .nav-icon {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            margin-bottom: 4px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            background: var(--bg-card);
            border: 1px solid var(--border);
        }

        .nav-item.active .nav-icon {
            background: var(--accent);
            color: var(--bg-primary);
            transform: scale(1.1) rotate(5deg);
            box-shadow: 0 8px 25px rgba(255,255,255,0.2);
        }

        .nav-label {
            font-size: 11px;
            font-weight: 600;
        }

        /* Content Sections */
        .section {
            display: none;
            padding: 20px;
            animation: fadeInSection 0.5s ease-out;
            position: relative;
            z-index: 1;
        }

        @keyframes fadeInSection {
            from { opacity: 0; transform: translateX(-30px); }
            to { opacity: 1; transform: translateX(0); }
        }

        .section.active {
            display: block;
        }

        /* Cards */
        .card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 25px;
            margin-bottom: 25px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            animation: cardEntry 0.6s ease-out;
            position: relative;
            overflow: hidden;
        }

        .card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: var(--gradient);
            opacity: 0;
            transition: opacity 0.3s;
        }

        .card:hover {
            transform: translateY(-5px);
            border-color: #333;
            box-shadow: 0 20px 40px rgba(255,255,255,0.05);
        }

        .card:hover::before {
            opacity: 1;
        }

        @keyframes cardEntry {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .card-title {
            font-size: 20px;
            font-weight: 700;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 12px;
            position: relative;
        }

        /* Stats Grid */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
            margin-bottom: 25px;
        }

        .stat-box {
            background: var(--gradient);
            padding: 30px 20px;
            border-radius: 20px;
            text-align: center;
            color: var(--bg-primary);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            animation: statPop 0.6s ease-out;
            position: relative;
            overflow: hidden;
        }

        .stat-box::after {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.3) 0%, transparent 70%);
            opacity: 0;
            transition: opacity 0.3s;
        }

        .stat-box:hover {
            transform: translateY(-8px) scale(1.05);
            box-shadow: 0 15px 35px rgba(255,255,255,0.2);
        }

        .stat-box:hover::after {
            opacity: 1;
        }

        @keyframes statPop {
            0% { opacity: 0; transform: scale(0.5); }
            50% { transform: scale(1.1); }
            100% { opacity: 1; transform: scale(1); }
        }

        .stat-number {
            font-size: 48px;
            font-weight: 800;
            margin-bottom: 8px;
            animation: countUp 1s ease-out;
        }

        @keyframes countUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .stat-label {
            font-size: 13px;
            opacity: 0.9;
            font-weight: 600;
        }

        /* Upload Area */
        .upload-area {
            border: 2px dashed var(--border);
            border-radius: 20px;
            padding: 50px 20px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            margin-bottom: 25px;
            background: var(--bg-secondary);
            position: relative;
            overflow: hidden;
        }

        .upload-area::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.05), transparent);
            transition: left 0.5s;
        }

        .upload-area:hover {
            border-color: var(--accent);
            transform: translateY(-5px);
            box-shadow: 0 15px 35px rgba(255,255,255,0.1);
        }

        .upload-area:hover::before {
            left: 100%;
        }

        .upload-icon {
            font-size: 64px;
            margin-bottom: 20px;
            animation: bounce 2s infinite;
        }

        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-15px); }
        }

        .upload-btn {
            background: var(--gradient);
            color: var(--bg-primary);
            padding: 14px 35px;
            border: none;
            border-radius: 25px;
            font-weight: 700;
            cursor: pointer;
            margin-top: 20px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
        }

        .upload-btn::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 0;
            height: 0;
            border-radius: 50%;
            background: rgba(0,0,0,0.2);
            transform: translate(-50%, -50%);
            transition: width 0.6s, height 0.6s;
        }

        .upload-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 30px rgba(255,255,255,0.3);
        }

        .upload-btn:hover::before {
            width: 300px;
            height: 300px;
        }

        /* File List */
        .file-list {
            margin-top: 25px;
        }

        .file-item {
            background: var(--bg-secondary);
            border: 1px solid var(--border);
            padding: 18px;
            border-radius: 15px;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 15px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            animation: fileSlide 0.4s ease-out;
        }

        @keyframes fileSlide {
            from { opacity: 0; transform: translateX(-20px); }
            to { opacity: 1; transform: translateX(0); }
        }

        .file-item:hover {
            border-color: #444;
            transform: translateX(8px);
            box-shadow: 0 8px 20px rgba(255,255,255,0.05);
        }

        .file-icon {
            font-size: 40px;
            animation: rotate 3s linear infinite;
        }

        @keyframes rotate {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .file-info {
            flex: 1;
        }

        .file-name {
            font-weight: 600;
            margin-bottom: 4px;
            color: var(--text-primary);
        }

        .file-size {
            font-size: 12px;
            color: var(--text-secondary);
        }

        .file-actions {
            display: flex;
            gap: 10px;
        }

        .btn-icon {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            border: 1px solid var(--border);
            background: var(--bg-card);
            color: var(--text-primary);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .btn-icon:hover {
            background: var(--accent);
            color: var(--bg-primary);
            transform: scale(1.15) rotate(15deg);
        }

        /* Timeline */
        .timeline {
            position: relative;
            padding-left: 35px;
        }

        .timeline::before {
            content: '';
            position: absolute;
            left: 12px;
            top: 0;
            bottom: 0;
            width: 2px;
            background: linear-gradient(to bottom, var(--accent), var(--border));
        }

        .timeline-item {
            position: relative;
            margin-bottom: 30px;
            background: var(--bg-secondary);
            padding: 25px;
            border-radius: 15px;
            border: 1px solid var(--border);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            animation: timelineEntry 0.6s ease-out;
        }

        @keyframes timelineEntry {
            from { opacity: 0; transform: translateX(-30px); }
            to { opacity: 1; transform: translateX(0); }
        }

        .timeline-item:hover {
            border-color: #444;
            transform: translateX(10px);
            box-shadow: 0 10px 30px rgba(255,255,255,0.05);
        }

        .timeline-item::before {
            content: '';
            position: absolute;
            left: -29px;
            top: 30px;
            width: 16px;
            height: 16px;
            border-radius: 50%;
            background: var(--accent);
            border: 3px solid var(--bg-primary);
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.3); opacity: 0.7; }
        }

        .timeline-year {
            font-size: 20px;
            font-weight: 800;
            color: var(--accent);
            margin-bottom: 10px;
        }

        .timeline-title {
            font-size: 17px;
            font-weight: 700;
            margin-bottom: 8px;
            color: var(--text-primary);
        }

        .timeline-desc {
            font-size: 14px;
            color: var(--text-secondary);
            line-height: 1.7;
        }

        /* Categories */
        .category-item {
            background: var(--bg-secondary);
            border: 1px solid var(--border);
            padding: 20px;
            border-radius: 15px;
            margin-bottom: 12px;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            animation: categorySlide 0.5s ease-out;
        }

        @keyframes categorySlide {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .category-item:hover {
            border-color: #444;
            transform: translateX(10px);
            box-shadow: 0 10px 30px rgba(255,255,255,0.08);
        }

        .category-icon {
            font-size: 40px;
            margin-bottom: 10px;
            display: inline-block;
            animation: float 3s ease-in-out infinite;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-8px); }
        }

        .category-name {
            font-weight: 700;
            margin-bottom: 5px;
            font-size: 16px;
        }

        .category-count {
            font-size: 12px;
            color: var(--text-secondary);
            margin-bottom: 10px;
        }

        .profession-list {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 8px;
            margin-top: 15px;
            padding-top: 15px;
            border-top: 1px solid var(--border);
        }

        .profession-item {
            font-size: 13px;
            color: var(--text-secondary);
            padding: 8px 12px;
            border-radius: 8px;
            transition: all 0.2s;
        }

        .profession-item:hover {
            background: var(--bg-card);
            color: var(--text-primary);
            transform: translateX(5px);
        }

        /* Info Cards */
        .info-card {
            background: var(--bg-secondary);
            border-left: 4px solid var(--accent);
            padding: 25px;
            border-radius: 15px;
            margin-bottom: 20px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            animation: infoSlide 0.5s ease-out;
        }

        @keyframes infoSlide {
            from { opacity: 0; transform: translateX(-30px); }
            to { opacity: 1; transform: translateX(0); }
        }

        .info-card:hover {
            transform: translateX(8px);
            box-shadow: 0 10px 30px rgba(255,255,255,0.08);
        }

        .info-title {
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 12px;
            color: var(--text-primary);
        }

        .info-text {
            font-size: 14px;
            line-height: 1.8;
            color: var(--text-secondary);
        }

        /* Progress Bar */
        .progress-container {
            margin: 20px 0;
        }

        .progress-label {
            display: flex;
            justify-content: space-between;
            margin-bottom: 10px;
            font-size: 13px;
            font-weight: 600;
        }

        .progress-bar {
            background: var(--bg-secondary);
            height: 10px;
            border-radius: 10px;
            overflow: hidden;
            position: relative;
        }

        .progress-fill {
            background: var(--gradient);
            height: 100%;
            border-radius: 10px;
            transition: width 1s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
        }

        .progress-fill::after {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
            animation: progressShine 2s infinite;
        }

        @keyframes progressShine {
            0% { left: -100%; }
            100% { left: 100%; }
        }

        /* Buttons */
        .btn {
            background: var(--gradient);
            color: var(--bg-primary);
            padding: 16px 32px;
            border: none;
            border-radius: 15px;
            font-weight: 700;
            cursor: pointer;
            width: 100%;
            margin-top: 20px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
            font-size: 15px;
        }

        .btn::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 0;
            height: 0;
            border-radius: 50%;
            background: rgba(0,0,0,0.2);
            transform: translate(-50%, -50%);
            transition: width 0.6s, height 0.6s;
        }

        .btn:hover {
            transform: translateY(-4px);
            box-shadow: 0 15px 35px rgba(255,255,255,0.3);
        }

        .btn:hover::before {
            width: 400px;
            height: 400px;
        }

        .btn-secondary {
            background: var(--bg-card);
            color: var(--text-primary);
            border: 1px solid var(--border);
        }

        .btn-secondary:hover {
            border-color: #444;
            box-shadow: 0 10px 25px rgba(255,255,255,0.1);
        }

        /* Hidden file input */
        #fileInput {
            display: none;
        }

        /* Loading Animation */
        .loading {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 3px solid rgba(255,255,255,0.3);
            border-top-color: var(--accent);
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* Responsive */
        @media (max-width: 600px) {
            .stats-grid {
                grid-template-columns: 1fr;
            }

            .stat-number {
                font-size: 36px;
            }

            .header h1 {
                font-size: 24px;
            }

            .profession-list {
                grid-template-columns: 1fr;
            }
        }

        /* Sync Indicator */
        .sync-indicator {
            position: fixed;
            top: 20px;
            right: 20px;
            background: var(--bg-card);
            border: 1px solid var(--border);
            padding: 10px 15px;
            border-radius: 25px;
            font-size: 12px;
            display: flex;
            align-items: center;
            gap: 8px;
            z-index: 1001;
            animation: slideInRight 0.5s ease-out;
        }

        @keyframes slideInRight {
            from { opacity: 0; transform: translateX(100px); }
            to { opacity: 1; transform: translateX(0); }
        }

        .sync-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #4CAF50;
            animation: pulse 2s infinite;
        }

        .sync-dot.syncing {
            background: #FFC107;
        }

        /* Empty State */
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: var(--text-secondary);
            animation: fadeIn 0.6s ease-out;
        }

        .empty-icon {
            font-size: 80px;
            margin-bottom: 20px;
            opacity: 0.5;
        }

        .empty-text {
            font-size: 16px;
            margin-bottom: 20px;
        }
    </style>
</head>
<body>
    <!-- Sync Indicator -->
    <div class="sync-indicator" id="syncIndicator">
        <div class="sync-dot" id="syncDot"></div>
        <span id="syncText">Sinxronlashuv...</span>
    </div>

    <!-- Header -->
    <div class="header">
        <h1>🏆 WorldSkills Shanghai 2026</h1>
        <p>48-chi Jahon Kasb Chempionati</p>
    </div>

    <!-- Kasblar Section -->
    <div id="section-professions" class="section active">
        <div class="card">
            <div class="card-title">📊 Jami Kompetensiyalar</div>
            <div class="stats-grid">
                <div class="stat-box">
                    <div class="stat-number" data-count="64">0</div>
                    <div class="stat-label">Jami Kasblar</div>
                </div>
                <div class="stat-box">
                    <div class="stat-number" data-count="6">0</div>
                    <div class="stat-label">Kategoriyalar</div>
                </div>
            </div>
        </div>

        <div id="categoriesContainer"></div>
    </div>

    <!-- Statistika Section -->
    <div id="section-statistics" class="section">
        <div class="card">
            <div class="card-title">📈 Mening Statistikam</div>
            <div class="stats-grid">
                <div class="stat-box">
                    <div class="stat-number" id="uploadedFiles">0</div>
                    <div class="stat-label">Yuklangan Fayllar</div>
                </div>
                <div class="stat-box">
                    <div class="stat-number" id="totalSize">0</div>
                    <div class="stat-label">Jami Hajm (MB)</div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-title">📄 PDF Ishlaringizni Yuklang</div>
            <div class="upload-area" onclick="document.getElementById('fileInput').click()">
                <div class="upload-icon">📎</div>
                <div style="font-size: 18px; font-weight: 700; margin-bottom: 10px;">
                    PDF faylni bu yerga tashlang
                </div>
                <div style="opacity: 0.8; font-size: 14px; margin-bottom: 20px;">
                    yoki bosing va tanlang
                </div>
                <button class="upload-btn">Fayl Tanlash</button>
            </div>
            <input type="file" id="fileInput" accept=".pdf" onchange="handleFileSelect(event)">

            <div style="background: var(--bg-secondary); padding: 20px; border-radius: 15px; margin-top: 20px; border: 1px solid var(--border);">
                <div style="font-size: 14px; margin-bottom: 10px; font-weight: 600;">
                    📌 Qabul qilinadigan fayllar:
                </div>
                <ul style="font-size: 13px; opacity: 0.9; padding-left: 20px; line-height: 2;">
                    <li>PDF format (max 10 MB)</li>
                    <li>Loyihalar, portfoliolar</li>
                    <li>Sertifikatlar</li>
                    <li>Ish namunalari</li>
                </ul>
            </div>

            <div class="file-list" id="fileList"></div>
        </div>
    </div>

    <!-- Tarix Section -->
    <div id="section-history" class="section">
        <div class="card">
            <div class="card-title">📜 WorldSkills Tarixi</div>
            <div class="timeline">
                <div class="timeline-item">
                    <div class="timeline-year">1950</div>
                    <div class="timeline-title">WorldSkills Tashkil Topdi</div>
                    <div class="timeline-desc">
                        Ispaniyada birinchi milliy kasb mahorati musobaqasi o'tkazildi.
                        Keyinchalik bu xalqaro harakatga aylandi.
                    </div>
                </div>

                <div class="timeline-item">
                    <div class="timeline-year">1953</div>
                    <div class="timeline-title">Birinchi Xalqaro Musobaqa</div>
                    <div class="timeline-desc">
                        Madrid, Ispaniyada birinchi xalqaro WorldSkills chempionati
                        12 mamlakat ishtirokida o'tkazildi.
                    </div>
                </div>

                <div class="timeline-item">
                    <div class="timeline-year">2001</div>
                    <div class="timeline-title">WorldSkills International</div>
                    <div class="timeline-desc">
                        Tashkilot rasman "WorldSkills International" nomini oldi va
                        dunyoning 50 dan ortiq mamlakatini qamrab oldi.
                    </div>
                </div>

                <div class="timeline-item">
                    <div class="timeline-year">2022</div>
                    <div class="timeline-title">O'zbekiston A'zo Bo'ldi</div>
                    <div class="timeline-desc">
                        O'zbekiston WorldSkills International tashkilotiga rasman
                        a'zo bo'ldi va milliy chempionatlarni o'tkaza boshladi.
                    </div>
                </div>

                <div class="timeline-item">
                    <div class="timeline-year">2026</div>
                    <div class="timeline-title">Shanghai 2026</div>
                    <div class="timeline-desc">
                        48-chi Jahon Kasb Chempionati Xitoyning Shanxay shahrida
                        o'tkaziladi. 64 ta kompetensiya bo'yicha musobaqalar.
                    </div>
                </div>
            </div>
        </div>

        <div class="info-card">
            <div class="info-title">🌍 WorldSkills Haqida</div>
            <div class="info-text">
                WorldSkills - dunyodagi eng yirik kasbiy mahorat musobaqasi bo'lib,
                18-22 yoshli yoshlarning kasbiy ko'nikmalarini rivojlantirish va
                namoyish etish uchun mo'ljallangan. Har ikki yilda bir marta o'tkaziladi.
            </div>
        </div>
    </div>

    <!-- Ma'lumot Section -->
    <div id="section-info" class="section">
        <div class="card">
            <div class="card-title">📅 Musobaqa Tafsilotlari</div>

            <div class="info-card">
                <div class="info-title">🏆 Chempionat</div>
                <div class="info-text">
                    <strong>Nomi:</strong> WorldSkills Shanghai 2026<br>
                    <strong>Nashri:</strong> 48-chi Jahon Kasb Chempionati<br>
                    <strong>Sana:</strong> 2026-yil<br>
                    <strong>Joy:</strong> Shanxay, Xitoy
                </div>
            </div>

            <div class="info-card">
                <div class="info-title">📋 Qatnashish Shartlari</div>
                <div class="info-text">
                    • Yosh: 18-22 yosh<br>
                    • Kasb: 64 ta kompetensiyadan biri<br>
                    • Tajriba: Professional daraja<br>
                    • Til: Ingliz tili (musobaqa tili)
                </div>
            </div>

            <div class="info-card">
                <div class="info-title">🎯 Bosqichlar</div>
                <div class="progress-container">
                    <div class="progress-label">
                        <span>Tayyorgarlik darajasi</span>
                        <span>25%</span>
                    </div>
                    <div class="progress-bar">
                        <div class="progress-fill" style="width: 0%" data-width="25"></div>
                    </div>
                </div>
                <div class="info-text" style="margin-top: 15px;">
                    1. Mintaqaviy saralash<br>
                    2. Milliy chempionat<br>
                    3. Xalqaro chempionat (Shanghai)<br>
                </div>
            </div>

            <div class="info-card">
                <div class="info-title">🏆 Mukofotlar</div>
                <div class="info-text">
                    🥇 Oltin medal - 1-o'rin<br>
                    🥈 Kumush medal - 2-o'rin<br>
                    🥉 Bronza medal - 3-o'rin<br>
                    🏅 Medallion of Excellence - 4-o'rin
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-title">📞 Aloqa</div>
            <div style="line-height: 2.2; font-size: 14px;">
                📧 Email: info@worldskills.uz<br>
                📱 Telefon: +998 71 123 45 67<br>
                🌐 Telegram: @worldskills_admin<br>
                🕐 Ish vaqti: Dush-Juma 9:00-18:00
            </div>
        </div>
    </div>

    <!-- Bottom Navigation -->
    <div class="bottom-nav">
        <div class="nav-item active" onclick="switchTab('professions')">
            <div class="nav-icon">💼</div>
            <div class="nav-label">Kasblar</div>
        </div>
        <div class="nav-item" onclick="switchTab('statistics')">
            <div class="nav-icon">📊</div>
            <div class="nav-label">Statistika</div>
        </div>
        <div class="nav-item" onclick="switchTab('history')">
            <div class="nav-icon">📜</div>
            <div class="nav-label">Tarix</div>
        </div>
        <div class="nav-item" onclick="switchTab('info')">
            <div class="nav-icon">ℹ️</div>
            <div class="nav-label">Ma'lumot</div>
        </div>
    </div>

    <script>
        // Data
        const professions = {
            "cat_001": {
                icon: "🏭",
                name_uz: "Ishlab chiqarish va Muhandislik",
                name_en: "Manufacturing & Engineering",
                count: 17,
                professions: [
                    { en: "Industrial Mechanics", uz: "Sanoat mexanikasi" },
                    { en: "Mechatronics", uz: "Mexatronika" },
                    { en: "Mechanical Engineering CAD", uz: "Mexanik muhandislik CAD" },
                    { en: "CNC Turning", uz: "CNC tokarlik ishlovi" },
                    { en: "CNC Milling", uz: "CNC frezalash" },
                    { en: "Welding", uz: "Payvandlash" },
                    { en: "Electronics", uz: "Elektronika" },
                    { en: "Industrial Control", uz: "Sanoat boshqaruvi" },
                    { en: "Autonomous Mobile Robotics", uz: "Avtonom mobil robototexnika" },
                    { en: "Industry 4.0", uz: "Sanoat 4.0" },
                    { en: "Chemical Laboratory Technology", uz: "Kimyo laboratoriya" },
                    { en: "Water Technology", uz: "Suv texnologiyasi" },
                    { en: "Additive Manufacturing", uz: "3D chop etish" },
                    { en: "Industrial Design Technology", uz: "Sanoat dizayni" },
                    { en: "Optoelectronic Technology", uz: "Optoelektronika" },
                    { en: "Renewable Energy", uz: "Qayta tiklanuvchi energiya" },
                    { en: "Robot Systems Integration", uz: "Robot tizimlari" }
                ]
            },
            "cat_002": {
                icon: "💻",
                name_uz: "Axborot va Kommunikatsiya",
                name_en: "Information & Communication",
                count: 8,
                professions: [
                    { en: "ICT Network Infrastructure", uz: "Tarmoq infratuzilmasi" },
                    { en: "Mobile Applications", uz: "Mobil ilovalar" },
                    { en: "Software Development", uz: "Dasturiy ta'minot" },
                    { en: "Web Technologies", uz: "Veb texnologiyalar" },
                    { en: "IT Network Administration", uz: "Tarmoq boshqaruvi" },
                    { en: "Cloud Computing", uz: "Bulutli hisoblash" },
                    { en: "Cyber Security", uz: "Kiberxavfsizlik" },
                    { en: "Software Testing", uz: "Dasturiy sinov" }
                ]
            },
            "cat_003": {
                icon: "🏗️",
                name_uz: "Qurilish",
                name_en: "Construction",
                count: 14,
                professions: [
                    { en: "Wall and Floor Tiling", uz: "Plitkalash" },
                    { en: "Plumbing and Heating", uz: "Santexnika" },
                    { en: "Electrical Installations", uz: "Elektr o'rnatish" },
                    { en: "Bricklaying", uz: "G'isht terish" },
                    { en: "Plastering", uz: "Suvoq" },
                    { en: "Painting", uz: "Bo'yash" },
                    { en: "Cabinetmaking", uz: "Duradgorlik" },
                    { en: "Joinery", uz: "Yig'ish ishlari" },
                    { en: "Carpentry", uz: "Yog'och ishlari" },
                    { en: "Landscape Gardening", uz: "Landshaft" },
                    { en: "Refrigeration", uz: "Sovutish" },
                    { en: "Concrete Work", uz: "Beton ishlari" },
                    { en: "Digital Construction", uz: "Raqamli qurilish" },
                    { en: "Security Technology", uz: "Xavfsizlik" }
                ]
            },
            "cat_004": {
                icon: "🚚",
                name_uz: "Transport",
                name_en: "Transportation",
                count: 8,
                professions: [
                    { en: "Autobody Repair", uz: "Kuzov ta'mirlash" },
                    { en: "Aircraft Maintenance", uz: "Samolyot xizmati" },
                    { en: "Automobile Technology", uz: "Avtomobil" },
                    { en: "Car Painting", uz: "Avtomobil bo'yash" },
                    { en: "Heavy Vehicle", uz: "Og'ir transport" },
                    { en: "Logistics", uz: "Logistika" },
                    { en: "Rail Vehicle", uz: "Temiryo'l" },
                    { en: "UAV Systems", uz: "Uchuvchisiz apparatlar" }
                ]
            },
            "cat_005": {
                icon: "🎨",
                name_uz: "Ijodiy San'at",
                name_en: "Creative Arts",
                count: 7,
                professions: [
                    { en: "Jewellery", uz: "Zargarlik" },
                    { en: "Floristry", uz: "Gulchilik" },
                    { en: "Fashion Technology", uz: "Moda" },
                    { en: "Graphic Design", uz: "Grafik dizayn" },
                    { en: "Visual Merchandising", uz: "Vizual savdo" },
                    { en: "3D Game Art", uz: "3D o'yin san'ati" },
                    { en: "Media Design", uz: "Media dizayn" }
                ]
            },
            "cat_006": {
                icon: "👥",
                name_uz: "Xizmatlar",
                name_en: "Social Services",
                count: 10,
                professions: [
                    { en: "Hairdressing", uz: "Sartaroshlik" },
                    { en: "Beauty Therapy", uz: "Go'zallik" },
                    { en: "Pâtisserie", uz: "Qandolatchilik" },
                    { en: "Cooking", uz: "Oshpazlik" },
                    { en: "Restaurant Service", uz: "Restoran" },
                    { en: "Health Care", uz: "Sog'liqni saqlash" },
                    { en: "Bakery", uz: "Nonvoychilik" },
                    { en: "Hotel Reception", uz: "Mehmonxona" },
                    { en: "Dental Prosthetics", uz: "Tish protezi" },
                    { en: "Retail Sales", uz: "Savdo" }
                ]
            }
        };

        let uploadedFiles = [];
        let currentLang = 'uz';
        let userData = {};

        // Initialize
        document.addEventListener('DOMContentLoaded', () => {
            const tg = window.Telegram.WebApp;
            tg.ready();
            tg.expand();

            // Get user data from Telegram
            const user = tg.initDataUnsafe?.user;
            if (user) {
                userData = {
                    id: user.id,
                    firstName: user.first_name,
                    lastName: user.last_name,
                    username: user.username
                };
                syncData();
            }

            // Load saved data
            loadData();

            // Animate counters
            animateCounters();

            // Animate progress bars
            setTimeout(animateProgressBars, 500);
        });

        // Sync Data with Bot
        async function syncData() {
            const syncDot = document.getElementById('syncDot');
            const syncText = document.getElementById('syncText');

            syncDot.classList.add('syncing');
            syncText.textContent = 'Sinxronlashuv...';

            try {
                // Send data to bot backend
                const response = await fetch('/api/sync', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        action: 'sync',
                        user: userData,
                        files: uploadedFiles,
                        timestamp: new Date().toISOString()
                    })
                });

                if (response.ok) {
                    syncDot.classList.remove('syncing');
                    syncText.textContent = 'Sinxronlashdi ✓';
                    setTimeout(() => {
                        syncText.textContent = 'Sinxronlashuv...';
                    }, 2000);
                }
            } catch (error) {
                console.log('Sync error:', error);
                syncDot.classList.remove('syncing');
                syncText.textContent = 'Sinxronlashuv xatosi';
            }

            // Save to localStorage
            saveData();
        }

        // Save Data
        function saveData() {
            localStorage.setItem('worldskills_files', JSON.stringify(uploadedFiles));
            localStorage.setItem('worldskills_user', JSON.stringify(userData));
        }

        // Load Data
        function loadData() {
            const savedFiles = localStorage.getItem('worldskills_files');
            const savedUser = localStorage.getItem('worldskills_user');

            if (savedFiles) {
                uploadedFiles = JSON.parse(savedFiles);
                updateFileList();
                updateStats();
            }

            if (savedUser) {
                userData = JSON.parse(savedUser);
            }
        }

        // Tab Switching
        function switchTab(tabName) {
            document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
            document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));

            document.getElementById(`section-${tabName}`).classList.add('active');
            event.currentTarget.classList.add('active');

            if (tabName === 'professions') {
                renderCategories();
                animateCounters();
            } else if (tabName === 'statistics') {
                updateStats();
            }

            // Sync data when switching tabs
            if (userData.id) {
                syncData();
            }
        }

        // Animate Counters
        function animateCounters() {
            const counters = document.querySelectorAll('.stat-number[data-count]');
            counters.forEach(counter => {
                const target = parseInt(counter.getAttribute('data-count'));
                const duration = 1500;
                const step = target / (duration / 16);
                let current = 0;

                const timer = setInterval(() => {
                    current += step;
                    if (current >= target) {
                        counter.textContent = target;
                        clearInterval(timer);
                    } else {
                        counter.textContent = Math.floor(current);
                    }
                }, 16);
            });
        }

        // Animate Progress Bars
        function animateProgressBars() {
            document.querySelectorAll('.progress-fill[data-width]').forEach(bar => {
                const width = bar.getAttribute('data-width');
                setTimeout(() => {
                    bar.style.width = width + '%';
                }, 100);
            });
        }

        // Render Categories
        function renderCategories() {
            const container = document.getElementById('categoriesContainer');
            if (container.children.length > 0) return;

            let delay = 0;
            Object.keys(professions).forEach((catId, index) => {
                const cat = professions[catId];
                const catDiv = document.createElement('div');
                catDiv.className = 'category-item';
                catDiv.style.animationDelay = `${delay}ms`;

                const profList = cat.professions.map((prof, idx) =>
                    `<div class="profession-item">${idx + 1}. ${currentLang === 'uz' ? prof.uz : prof.en}</div>`
                ).join('');

                catDiv.innerHTML = `
                    <div class="category-icon">${cat.icon}</div>
                    <div class="category-name">${currentLang === 'uz' ? cat.name_uz : cat.name_en}</div>
                    <div class="category-count">${cat.count} ${currentLang === 'uz' ? 'ta kasb' : 'skills'}</div>
                    <div class="profession-list">
                        ${profList}
                    </div>
                `;

                container.appendChild(catDiv);
                delay += 100;
            });
        }

        // File Upload
        function handleFileSelect(event) {
            const file = event.target.files[0];
            if (!file) return;

            if (file.type !== 'application/pdf') {
                alert('⚠️ Faqat PDF fayllar qabul qilinadi!');
                return;
            }

            if (file.size > 10 * 1024 * 1024) {
                alert('⚠️ Fayl hajmi 10 MB dan oshmasligi kerak!');
                return;
            }

            uploadedFiles.push({
                name: file.name,
                size: (file.size / 1024 / 1024).toFixed(2),
                date: new Date().toLocaleDateString('uz-UZ'),
                uploadedBy: userData.firstName || 'User'
            });

            updateFileList();
            updateStats();
            saveData();
            syncData();

            // Success animation
            const uploadArea = document.querySelector('.upload-area');
            uploadArea.style.borderColor = '#4CAF50';
            uploadArea.style.background = 'rgba(76, 175, 80, 0.1)';
            setTimeout(() => {
                uploadArea.style.borderColor = '';
                uploadArea.style.background = '';
            }, 2000);

            alert('✅ Fayl muvaffaqiyatli yuklandi!');
        }

        function updateFileList() {
            const list = document.getElementById('fileList');
            if (uploadedFiles.length === 0) {
                list.innerHTML = `
                    <div class="empty-state">
                        <div class="empty-icon">📄</div>
                        <div class="empty-text">Hali hech qanday fayl yuklanmagan</div>
                    </div>
                `;
                return;
            }

            list.innerHTML = '<div style="font-weight: 700; margin-bottom: 15px; font-size: 16px;">📄 Yuklangan fayllar:</div>';

            uploadedFiles.forEach((file, idx) => {
                const fileDiv = document.createElement('div');
                fileDiv.className = 'file-item';
                fileDiv.style.animationDelay = `${idx * 50}ms`;
                fileDiv.innerHTML = `
                    <div class="file-icon">📄</div>
                    <div class="file-info">
                        <div class="file-name">${file.name}</div>
                        <div class="file-size">${file.size} MB • ${file.date} • ${file.uploadedBy}</div>
                    </div>
                    <div class="file-actions">
                        <button class="btn-icon" onclick="downloadFile(${idx})" title="Yuklab olish">⬇️</button>
                        <button class="btn-icon" onclick="deleteFile(${idx})" title="O'chirish">🗑️</button>
                    </div>
                `;
                list.appendChild(fileDiv);
            });
        }

        function updateStats() {
            const filesCount = document.getElementById('uploadedFiles');
            const totalSize = document.getElementById('totalSize');

            if (filesCount && totalSize) {
                filesCount.textContent = uploadedFiles.length;
                const size = uploadedFiles.reduce((acc, f) => acc + parseFloat(f.size), 0);
                totalSize.textContent = size.toFixed(2);
            }
        }

        function downloadFile(idx) {
            const file = uploadedFiles[idx];
            alert(`📥 Fayl yuklab olinmoqda:\n\n${file.name}\n${file.size} MB`);
        }

        function deleteFile(idx) {
            if (confirm('🗑️ Bu faylni o\'chirmoqchimisiz?')) {
                uploadedFiles.splice(idx, 1);
                updateFileList();
                updateStats();
                saveData();
                syncData();
            }
        }
    </script>
</body>
</html>